from pathlib import Path
import sys

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")

marker = "# AUTO_MIGRATE_DATABASE"

if marker not in text:
    block = """    # AUTO_MIGRATE_DATABASE
    echo "[DATABASE] Áp dụng migrations..."
    docker exec -w /app "$C" python manage.py migrate --noinput

"""

    possible_markers = [
        "    # Kiểm tra cú pháp trước khi khởi động lại web.\n",
        "    docker exec \"$C\" python -m py_compile",
        "    docker exec -w /app \"$C\" \\\n        python manage.py check",
    ]

    inserted = False

    for target in possible_markers:
        if target in text:
            text = text.replace(
                target,
                block + target,
                1,
            )
            inserted = True
            break

    if not inserted:
        # Chèn trước phần restart nếu cấu trúc script đã thay đổi.
        target = 'docker restart "$C"'

        if target in text:
            text = text.replace(
                target,
                block + target,
                1,
            )
            inserted = True

    if inserted:
        path.write_text(text, encoding="utf-8")
        print("[OK] Đã thêm AUTO_MIGRATE_DATABASE.")
    else:
        print(
            "[CẢNH BÁO] Không xác định được vị trí chèn "
            "trong apply-customizations.sh."
        )
else:
    print(
        "[CẢNH BÁO] Chưa tìm thấy apply-customizations.sh; "
        "phần database hiện tại vẫn đã được sửa."
    )
PY
